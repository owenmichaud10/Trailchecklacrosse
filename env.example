# Copy this file to .env.local and add your Formspree form ID.
# .env.local is private and never gets committed to git.
#
# Setup: https://formspree.io — create a form that sends to klm0027@yahoo.com

FORMSPREE_FORM_ID=paste_your_form_id_here
CONTACT_TO_EMAIL=klm0027@yahoo.com

# Set this to your live URL after deploying (e.g. https://your-site.vercel.app)
NEXT_PUBLIC_SITE_URL=https://trailchecklacrosse.com
